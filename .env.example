# =============================================================
# .env.example — Variables de entorno para cargas-integrado
# =============================================================
# Este proyecto es una Single Page Application (SPA) construida
# con React + Vite. No requiere variables de entorno en runtime
# para el frontend base.
#
# ADVERTENCIA: Las variables con prefijo VITE_ son incorporadas
# en el bundle del cliente y quedan visibles públicamente.
# NUNCA uses VITE_ para claves de API secretas (OpenAI, Kommo,
# etc.). Las llamadas a APIs con autenticación deben pasar
# siempre por un backend proxy.
#
# Si en el futuro se agregan integraciones con APIs públicas
# o endpoints propios del proyecto, definir aquí:
#
# VITE_API_URL=https://tu-backend.onrender.com

# PORT — Solo para desarrollo local con `npm start` (vite preview).
# En Render (Web Service) este valor es inyectado automáticamente
# y NO debe definirse manualmente en el panel de variables.
PORT=4173
